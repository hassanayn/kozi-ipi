# Convex local development deployment name, generated by `bun run convex:dev`.
CONVEX_DEPLOYMENT=

# Public Convex URL used by the Next.js client.
NEXT_PUBLIC_CONVEX_URL=

# Optional public Convex HTTP actions site URL.
NEXT_PUBLIC_CONVEX_SITE_URL=

# Private admin key for protected Convex HTTP actions.
# Keep the real value in local/private env only.
ADMIN_API_KEY=
